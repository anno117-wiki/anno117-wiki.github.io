{
  "name": "anno117-calculator-jp",
  "version": "1.0.0",
  "description": "Anno 117 Production Calculator - Japanese Edition",
  "author": "kojifujita0822 <kojifujita0822@gmail.com>",
  "license": "UNLICENSED",
  "keywords": [
    "anno",
    "anno117",
    "calculator",
    "production-chain",
    "japanese",
    "vue3",
    "typescript",
    "vite"
  ],
  "scripts": {
    "generate": "bun run tools/generate-goods-list.ts && bun run tools/generate-items-list.ts",
    "dev": "vite",
    "dev:legacy": "bun run devserver.ts --dev",
    "build": "vue-tsc --noEmit && vite build",
    "build:vite": "vite build",
    "preview": "vite preview",
    "dev:wiki": "bun run --cwd apps/wiki dev",
    "build:wiki": "bun run --cwd apps/wiki build",
    "preview:wiki": "bun run --cwd apps/wiki preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "build:site": "bun run scripts/build-site.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "typescript": "^5.6.0",
    "vue-tsc": "^2.2.0"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^8.0.16",
    "vue": "^3.5.35"
  }
}
